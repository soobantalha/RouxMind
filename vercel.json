{
  "version": 2,
  "builds": [
    {
      "src": "api/recipe.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "recipe.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/recipe",
      "dest": "/api/recipe.js"
    },
    {
      "src": "/api/recipe/(.*)",
      "dest": "/api/recipe.js"
    },
    {
      "src": "/recipe.html",
      "dest": "/recipe.html"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}